rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming(req) {
      return req.resource.data;
    }

    // Employee Validation
    function isValidEmployee(data) {
      return data.keys().hasAll(['id', 'name', 'role', 'photoUrl', 'attendanceRate', 'avgCheckIn'])
        && data.keys().size() == 6
        && data.id is string && data.id.size() <= 100
        && data.name is string && data.name.size() <= 200
        && data.role is string && data.role.size() <= 200
        && data.photoUrl is string && data.photoUrl.size() <= 1000
        && data.attendanceRate is int && data.attendanceRate >= 0 && data.attendanceRate <= 100
        && data.avgCheckIn is string && data.avgCheckIn.size() <= 10;
    }

    // LeaveBalance Validation
    function isValidLeaveBalance(data) {
      return data.keys().hasAll(['annual', 'sickUsed', 'specialAvailable'])
        && data.keys().size() == 3
        && data.annual is int && data.annual >= 0
        && data.sickUsed is int && data.sickUsed >= 0
        && data.specialAvailable is int && data.specialAvailable >= 0;
    }

    // AttendanceRecord Validation
    function isValidAttendanceRecord(data) {
      return data.keys().hasAll(['id', 'employeeId', 'employeeName', 'date', 'dateKey', 'checkInTime', 'checkInStatus', 'locationName', 'checkInSelfie'])
        && data.id is string && data.id.size() <= 100
        && data.employeeId is string && data.employeeId.size() <= 100
        && data.employeeName is string && data.employeeName.size() <= 200
        && data.date is string && data.date.size() <= 100
        && data.dateKey is string && data.dateKey.size() <= 20
        && data.checkInTime is string && data.checkInTime.size() <= 10
        && data.checkInStatus is string && data.checkInStatus.size() <= 50
        && data.locationName is string && data.locationName.size() <= 200
        && data.checkInSelfie is string && data.checkInSelfie.size() <= 1000000;
    }

    // LeaveRequest Validation
    function isValidLeaveRequest(data) {
      return data.keys().hasAll(['id', 'employeeId', 'employeeName', 'employeeRole', 'employeePhoto', 'type', 'startDate', 'endDate', 'days', 'reason', 'status', 'submittedAt'])
        && data.keys().size() == 12
        && data.id is string && data.id.size() <= 100
        && data.employeeId is string && data.employeeId.size() <= 100
        && data.employeeName is string && data.employeeName.size() <= 200
        && data.employeeRole is string && data.employeeRole.size() <= 200
        && data.employeePhoto is string && data.employeePhoto.size() <= 1000
        && data.type is string && data.type.size() <= 100
        && data.startDate is string && data.startDate.size() <= 100
        && data.endDate is string && data.endDate.size() <= 100
        && data.days is int && data.days >= 0
        && data.reason is string && data.reason.size() <= 2000
        && data.status is string && (data.status == 'PENDING' || data.status == 'APPROVED' || data.status == 'REJECTED')
        && data.submittedAt is string && data.submittedAt.size() <= 100;
    }

    match /employees/{employeeId} {
      allow read: if true;
      allow create, update: if isValidId(employeeId) && isValidEmployee(incoming(request));
      allow delete: if isValidId(employeeId);
    }

    match /leaveBalances/{employeeId} {
      allow read: if true;
      allow create, update: if isValidId(employeeId) && isValidLeaveBalance(incoming(request));
      allow delete: if isValidId(employeeId);
    }

    match /attendance/{recordId} {
      allow read: if true;
      allow create, update: if isValidId(recordId) && isValidAttendanceRecord(incoming(request));
      allow delete: if isValidId(recordId);
    }

    match /leaveRequests/{requestId} {
      allow read: if true;
      allow create, update: if isValidId(requestId) && isValidLeaveRequest(incoming(request));
      allow delete: if isValidId(requestId);
    }
  }
}
